TEUMSEOUL_APP_NAME=TeumSeoul API
TEUMSEOUL_APP_ENV=local
TEUMSEOUL_DEBUG=false
API_PREFIX=/api
DATABASE_URL=sqlite:///./localhub.db
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=8
RECOMMENDATION_TIMEOUT_SECONDS=30
OPENAI_MAX_CANDIDATES=5
RECOMMENDATION_CANDIDATE_LIMIT=18
LOG_LEVEL=INFO
